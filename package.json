{
  "name": "codex-limit-auto-reset",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env src/main.ts",
    "dev:cli": "node --env-file-if-exists=.env src/cli.ts",
    "dev:reset": "node --env-file-if-exists=.env src/reset.ts",
    "start": "node --env-file-if-exists=.env src/main.ts",
    "start:cli": "node --env-file-if-exists=.env src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "execa": "9.6.1",
    "split2": "4.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "26.1.1",
    "@types/split2": "4.2.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
